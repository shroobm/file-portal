{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Permissions for the main widget window: list portals, send files, and react to drag-and-drop.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-set-size",
    "core:window:allow-set-position"
  ]
}
