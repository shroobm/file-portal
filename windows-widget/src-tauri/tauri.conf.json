{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "File Portal",
  "version": "0.1.0",
  "identifier": "dev.fileportal.widget",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "File Portal",
        "width": 480,
        "height": 224,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/icon.ico"
    ]
  }
}
